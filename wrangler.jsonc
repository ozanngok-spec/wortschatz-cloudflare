{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mein-wortschatz",
  "compatibility_date": "2025-03-12",
  "main": "worker.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": ["0 8 * * *"]
  }
}
